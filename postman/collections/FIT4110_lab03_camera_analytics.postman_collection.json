    {
      "name": "02_Auth",
      "item": [
        {
          "name": "GET /camera-events/recent - valid token is accepted",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/camera-events/recent?limit=1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Valid token request returns success', function () { pm.expect(pm.response.code).to.eql(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /camera-events - missing token is rejected on real service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"eventType\":\"camera.motion.detected\",\"eventId\":\"0196fb3d-4ad7-7d1e-9f49-5d5148d2babc\",\"occurredAt\":\"2026-05-10T08:00:00Z\",\"cameraId\":\"CAM-007\",\"sourceService\":\"camera-stream\",\"correlationId\":\"0196fb3d-4ad7-7d1e-9f49-5d5148d2b000\",\"detectionId\":\"0196fb3d-4ad7-7d1e-9f49-5d5148d2b111\",\"motionType\":\"HUMAN\",\"imageRef\":\"https://cdn.campus.local/camera/CAM-007/frame-001.jpg\",\"confidence\":0.92}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/camera-events"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: Prism does not enforce real auth', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Missing token returns 401 or 403', function () { pm.expect([401, 403]).to.include(pm.response.code); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /camera-events - invalid token is rejected on real service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer invalid-token" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"eventType\":\"camera.motion.detected\",\"eventId\":\"0196fb3d-4ad7-7d1e-9f49-5d5148d2babc\",\"occurredAt\":\"2026-05-10T08:00:00Z\",\"cameraId\":\"CAM-007\",\"sourceService\":\"camera-stream\",\"correlationId\":\"0196fb3d-4ad7-7d1e-9f49-5d5148d2b000\",\"detectionId\":\"0196fb3d-4ad7-7d1e-9f49-5d5148d2b111\",\"motionType\":\"HUMAN\",\"imageRef\":\"https://cdn.campus.local/camera/CAM-007/frame-001.jpg\",\"confidence\":0.92}",
              "options": { "raw": { "language": "json" } }
