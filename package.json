{
  "name": "fit4110_lab03_postman_mock_testing",
  "version": "0.3.0",
  "private": true,
  "description": "FIT4110 Lab 03 - Postman, Mock Server, Contract Testing, Newman CI",
  "scripts": {
    "mock:camera": "prism mock contracts/camera-analytics.openapi.yaml -p 4010 --host 0.0.0.0",
    "mock:vision": "prism mock contracts/ai-vision.openapi.yaml -p 4011 --host 0.0.0.0",
    "mock:all": "sh -c 'npm run mock:camera & npm run mock:vision & wait'",
    "lint:contracts": "spectral lint contracts/*.yaml --fail-severity error",
    "test:mock": "newman run postman/collections/FIT4110_lab03_camera_analytics.postman_collection.json -e postman/environments/FIT4110_lab03_camera_analytics_mock.postman_environment.json --reporters cli,junit --reporter-junit-export reports/newman-report-mock.xml",
    "test:local": "newman run postman/collections/FIT4110_lab03_camera_analytics.postman_collection.json -e postman/environments/FIT4110_lab03_camera_analytics_local.postman_environment.json --reporters cli,junit --reporter-junit-export reports/newman-report-local.xml",
    "test:html": "newman run postman/collections/FIT4110_lab03_camera_analytics.postman_collection.json -e postman/environments/FIT4110_lab03_camera_analytics_mock.postman_environment.json --reporters cli,htmlextra --reporter-htmlextra-export reports/newman-report.html",
    "test:ci": "npm run lint:contracts && npm run test:mock"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.14.2",
    "@stoplight/spectral-cli": "^6.15.0",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1",
    "wait-on": "^7.2.0"
  }
}
